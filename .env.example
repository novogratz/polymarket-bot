# Copy this file to .env and fill in your values. Never commit .env.
#
# IMPORTANT : ce fichier ne contient QUE les secrets, endpoints, paths et
# machine state. Toute la stratégie (sizing, filtres, exits, fallbacks,
# auto-tune, BTC edge, telemetry…) est définie dans les profils TOML
# (`configs/profiles/<nom>.toml`).
#
# Pourquoi : `apply_profile_to_env(override=False)` n'écrase jamais une
# variable déjà posée par .env. Si tu remets une clé stratégie ici, le
# profil ne pourra plus la changer (shadowing silencieux).
#
# Voir docs/PROFILES.md pour la liste complète des clés profil.

# ---- Authentication (required for live trading) ----
POLYMARKET_PRIVATE_KEY=0x_replace_me
POLYMARKET_FUNDER_ADDRESS=0x_replace_me
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNATURE_TYPE=1

# ---- Endpoints ----
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com

# ---- Paths ----
POLYMARKET_STATE_PATH=data/paper_state.json
POLYMARKET_TRADE_JOURNAL_PATH=data/trade_journal.jsonl
POLYMARKET_STRATEGY_OVERRIDES_PATH=data/strategy_overrides.json

# ---- Machine state ----
# Bankroll présumée en live avant la 1re synchro CLOB. 0 = ne pas pré-supposer.
# Override possible côté profil via [sizing].assumed_live_balance_usd.
POLYMARKET_ASSUME_LIVE_BALANCE_USD=0
# Synchroniser les positions live depuis Polymarket dans le ledger local.
POLYMARKET_SYNC_LIVE_POSITIONS=1

# --- Telegram alerts (push-only, best-effort) ---
# Désactivées tant que TELEGRAM_BOT_TOKEN est vide.
# Crée un bot via @BotFather et récupère son token, puis ton chat_id
# via https://api.telegram.org/bot<TOKEN>/getUpdates après avoir envoyé
# un message au bot.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID_LIVE=
# TELEGRAM_CHAT_ID_DRY_RUN=
# TELEGRAM_ALERT_TRADES=1
# TELEGRAM_ALERT_ERRORS=1
# TELEGRAM_ALERT_THRESHOLDS=1
# TELEGRAM_ALERT_HEARTBEAT=1
# TELEGRAM_HEARTBEAT_MINUTES=30
# TELEGRAM_DRAWDOWN_PCT=10.0
# TELEGRAM_BIG_WIN_USD=10.0
# TELEGRAM_BIG_LOSS_USD=5.0
# TELEGRAM_EQUITY_FLOOR_USD=50.0
# TELEGRAM_DEDUPE_WINDOW_SEC=300
